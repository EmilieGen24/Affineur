{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="container register">
    <h2>Inscrivez-vous et créez votre fiche</h2>
    <div class="form-register">
        {{form_start(userform)}}
            {{form_widget(userform)}}
            <button class="btn-register">S'inscrire</button>
        {{form_end(userform)}}
        <div>
            <a href="{{ path("app_login") }}">Déjà inscrit ? Se connecter</a>
        </div>
    </div>

</div>
{% endblock %}
